# Model cache
# Commit the ONNX model files for Streamlit Cloud after running download_model.py.
.model_cache/*.lock
.model_cache/**/*.h5
.model_cache/**/pytorch_model.bin
.model_cache/**/flax_model*
.model_cache/**/tf_model*
.model_cache/**/rust_model*
.model_cache/**/*.msgpack
.model_cache/**/model_qint8_arm64.onnx
.model_cache/**/model_qint8_avx512.onnx
.model_cache/**/model_quint8_avx2.onnx
.model_cache/**/model_O4.onnx

# Vector store
# Commit vectorstore/db_faiss for Streamlit Cloud after building it locally.
# If GitHub size limits block the files, use Git LFS.
